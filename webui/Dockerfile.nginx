# Frontend-only WebUI image

FROM node:20.19.2-bullseye-slim AS build

WORKDIR /webui/frontend
COPY webui/frontend/package*.json ./
RUN if [ -f package-lock.json ]; then npm ci; else npm install; fi
COPY webui/frontend/ ./
RUN node node_modules/typescript/bin/tsc && node node_modules/vite/bin/vite.js build

FROM nginx:1.27-alpine
COPY --from=build /webui/frontend/dist/ /usr/share/nginx/html/
COPY webui/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 8080