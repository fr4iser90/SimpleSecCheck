# =============================================================================
# SimpleSecCheck Environment Variables
# =============================================================================
# Copy this file to .env and adjust values as needed
# For Production: Use docker compose --profile prod up --build
# For Development: Use docker compose --profile dev up --build
# =============================================================================

# -----------------------------------------------------------------------------
# ENVIRONMENT MODE (REQUIRED!)
# -----------------------------------------------------------------------------
# Set to "dev" for Development Mode or "prod" for Production Mode
# This controls which features are enabled/disabled
# 
# Development Mode:
#   - All scan types allowed (Code, Website, Network)
#   - No session management
#   - No queue system
#   - Auto-shutdown enabled
#
# Production Mode:
#   - Only Git scans allowed
#   - PostgreSQL database required
#   - Session management enabled
#   - Queue system enabled
#   - Auto-shutdown disabled
#
# Change this value to switch between modes:
ENVIRONMENT=dev
# ENVIRONMENT=prod

# ----------------------------------------------------------------------------
# SCAN TARGET (Unified input)
# ----------------------------------------------------------------------------
# Website scans: SCAN_TARGET=https://example.com
# Code scans: SCAN_TARGET=/path/to/project (for direct CLI runs)
# Note: WebUI supplies SCAN_TARGET automatically.
SCAN_TARGET=

# -----------------------------------------------------------------------------
# API Tokens (Optional - for authenticated features)
# -----------------------------------------------------------------------------
# Leave empty if you don't have a token

# NVD API Token - For OWASP Dependency Check
# Get from: https://nvd.nist.gov/developers/request-an-api-key
# Provides higher rate limits for vulnerability database lookups
NVD_API_KEY=

# -----------------------------------------------------------------------------
# PRODUCTION ONLY - OWASP Auto-Update Configuration
# -----------------------------------------------------------------------------
# Automatic OWASP database updates in Production (default: enabled)
# In Production: Updates run automatically in background
# In Development: Manual updates via UI button
OWASP_AUTO_UPDATE_ENABLED=true

# Update interval: Update database if older than X days (default: 7)
OWASP_AUTO_UPDATE_INTERVAL_DAYS=7

# Check interval: How often to check database age in hours (default: 24)
# Checks every 24 hours if database needs update
OWASP_AUTO_UPDATE_CHECK_INTERVAL_HOURS=24

# Snyk Token - For Snyk vulnerability scanning
# Get from: https://snyk.io/user/api
# Enables cloud-based vulnerability scanning with Snyk
SNYK_TOKEN=

# -----------------------------------------------------------------------------
# PRODUCTION ONLY - PostgreSQL Database Configuration
# -----------------------------------------------------------------------------
# ⚠️ REQUIRED for Production Mode (docker-compose.yml)
# These are NOT needed for Development Mode

# PostgreSQL Password (REQUIRED for Production!)
# Generate a strong password: openssl rand -base64 32
POSTGRES_PASSWORD=

# PostgreSQL Database Name (optional, default: simpleseccheck)
POSTGRES_DB=simpleseccheck

# PostgreSQL User (optional, default: ssc_user)
POSTGRES_USER=ssc_user

# ----------------------------------------------------------------------------
# PRODUCTION ONLY - Container UID/GID for volume permissions
# ----------------------------------------------------------------------------
# Ensure /app/results (host-mounted) is writable by the container user
# Set these to your host user/group IDs if you see permission errors
PUID=1000
PGID=1000

# -----------------------------------------------------------------------------
# AUTHENTICATION MODES
# -----------------------------------------------------------------------------
# Authentication mode: free|basic|jwt
# 
# FREE Mode (default): Public service, no login required, everyone gets session
# BASIC Mode: Username/password login required, session-based
# JWT Mode: Token-based authentication (Keycloak, Auth0, Azure AD)
AUTH_MODE=free

# Whether login is required (derived from AUTH_MODE)
# FREE: false, BASIC/JWT: true
LOGIN_REQUIRED=false

# Session secret key for session management
SESSION_SECRET=your-session-secret-key-here

# Session duration in seconds (default: 86400 = 24 hours)
SESSION_DURATION=86400

# Session cookie name (default: session_id)
SESSION_COOKIE_NAME=session_id

# Session header name (default: X-Session-ID)
SESSION_HEADER_NAME=X-Session-ID

# -----------------------------------------------------------------------------
# PRODUCTION ONLY - Queue Configuration
# -----------------------------------------------------------------------------
# Maximum queue length (default: 1000)
MAX_QUEUE_LENGTH=1000

# Maximum concurrent scans (default: 1 - UNTESTED, adjust based on server capacity)
MAX_CONCURRENT_SCANS=1

# -----------------------------------------------------------------------------
# LOGGING CONFIGURATION (All Services)
# -----------------------------------------------------------------------------
# Log level for all services (backend, worker, scanner)
# Options: DEBUG, INFO, WARNING, ERROR
# - DEBUG: Very verbose, shows all logs (Development)
# - INFO: Normal logging, shows important events (Default)
# - WARNING: Only warnings and errors (Production)
# - ERROR: Only errors (Minimal)
# 
# All containers (backend, worker) use this LOG_LEVEL from .env
# Individual containers can override internally if needed
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# PRODUCTION ONLY - Rate Limiting
# -----------------------------------------------------------------------------
# Rate limits per session
RATE_LIMIT_PER_SESSION_SCANS=10
RATE_LIMIT_PER_SESSION_REQUESTS=100

# Rate limits per IP address
RATE_LIMIT_PER_IP_SCANS=50
RATE_LIMIT_PER_IP_REQUESTS=1000

# -----------------------------------------------------------------------------
# PRODUCTION ONLY - Size Limits
# -----------------------------------------------------------------------------
# Maximum ZIP upload size (default: 100M)
MAX_ZIP_UPLOAD_SIZE=100M

# Maximum Git repository size (default: 500M)
MAX_GIT_REPO_SIZE=500M

# Maximum disk usage per scan (default: 2G)
MAX_SCAN_DISK_USAGE=2G

# -----------------------------------------------------------------------------
# PRODUCTION ONLY - Scan Deduplication
# -----------------------------------------------------------------------------
# Age in days for scan deduplication (default: 7)
SCAN_DEDUPLICATION_AGE_DAYS=7

# -----------------------------------------------------------------------------
# PRODUCTION ONLY - Optional Features
# -----------------------------------------------------------------------------
# Enable statistics collection (default: true)

STATISTICS_ENABLED=true

# Enable ZIP upload feature (default: false - RECOMMENDED for security)
# ⚠️ SECURITY NOTE: ZIP upload allows users to upload arbitrary code
#   - If disabled: Only Git repositories can be scanned (safer, recommended)
#   - If enabled: Users can upload ZIP files (higher risk of malicious code)
#   - Recommendation: Keep disabled initially, enable only if needed
#   - With Git-only: You can ban the Git user (GitHub/GitLab username) if malicious code is detected
#   - With ZIP upload: You can only ban the session, not the Git user (harder to track)
#   - Set to "false" to disable ZIP upload and only allow Git repository scans
ZIP_UPLOAD_ENABLED=false

# CORS allowed origins (comma-separated, empty = no CORS)
# Example: https://example.com,https://app.example.com
CORS_ALLOWED_ORIGINS=

# -----------------------------------------------------------------------------
# DEVELOPMENT ONLY - Optional Overrides
# -----------------------------------------------------------------------------
# These can override defaults in Development Mode
# Most settings use sensible defaults and don't need to be set

# Enable metadata collection in Dev (default: false)
# METADATA_COLLECTION=false

# Development size limits (more generous than Production)
# MAX_ZIP_UPLOAD_SIZE=500M
# MAX_GIT_REPO_SIZE=1G
# MAX_SCAN_DISK_USAGE=5G

# -----------------------------------------------------------------------------
# QUEUE CLEANUP (Always Enabled)
# -----------------------------------------------------------------------------
# Automatic cleanup of old completed/failed queue items
# QUEUE_CLEANUP_INTERVAL_HOURS=24        # How often to run cleanup (default: 24 hours)
# QUEUE_CLEANUP_MAX_AGE_DAYS=7          # Delete items older than X days (default: 7 days)